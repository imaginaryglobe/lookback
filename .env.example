# Don't edit this by hand -- run `python setup.py` to generate your own .env.
# (This file just documents what setup.py writes, for reference/manual setups.)

# --- Storage ---
# Folder on your local drive that should be indexed
SSD_PATH=C:\path\to\your\media\

# --- Ollama ---
# If Ollama runs on this same computer, leave these as-is.
# If it runs on another computer, setup.py points this at localhost too --
# an SSH tunnel (start_tunnel.bat) forwards that computer's Ollama port here.
OLLAMA_URL=http://localhost:11434
OLLAMA_REMOTE=false
VISION_MODEL=moondream
EMBED_MODEL=nomic-embed-text
QUERY_MODEL=llama3.2

# --- SSH tunnel (only used when OLLAMA_REMOTE=true) ---
OLLAMA_SSH_USER=youruser
OLLAMA_HOST=192.168.1.x

# --- Qdrant ---
# "embedded" (default) runs Qdrant in-process at QDRANT_PATH -- no Docker or
# separate database install needed. "server" connects to a running Qdrant
# instance (e.g. via docker-compose.yml) at QDRANT_HOST:QDRANT_PORT -- useful
# if you want multiple app instances sharing one database, or run Qdrant elsewhere.
QDRANT_MODE=embedded
QDRANT_PATH=./qdrant_data
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=media_index
